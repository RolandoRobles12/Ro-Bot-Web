rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAvivaDomain() {
      return isAuthenticated()
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@avivacredito[.]com');
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAvivaDomain() && getUserRole() == 'admin';
    }

    function isEditor() {
      return isAvivaDomain() && (getUserRole() == 'editor' || getUserRole() == 'admin');
    }

    function isViewer() {
      return isAvivaDomain() && getUserRole() != null;
    }

    match /invitations/{email} {
      allow get: if isAvivaDomain() && request.auth.token.email == email;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAvivaDomain();
      allow create: if isAvivaDomain() && request.auth.uid == userId;
      allow update: if isAdmin()
        || (isAvivaDomain()
            && request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    match /workspaces/{workspaceId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    match /workspace_settings/{docId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /scheduled_messages/{messageId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /message_history/{historyId} {
      allow read: if isViewer();
      allow create: if isAvivaDomain();
      allow update, delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /campaign_executions/{execId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isAdmin();
    }

    match /hubspot_connections/{connectionId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    match /rules/{ruleId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /sales_users/{userId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }
  }
}
