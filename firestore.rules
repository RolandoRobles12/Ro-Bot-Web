rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAvivaDomain() {
      return isAuthenticated()
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@avivacredito\\.com');
    }

    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.role : null;
    }

    function isAdmin() {
      return isAvivaDomain() && getUserRole() == 'admin';
    }

    function isEditor() {
      let role = getUserRole();
      return isAvivaDomain() && (role == 'editor' || role == 'admin');
    }

    function isViewer() {
      return isAvivaDomain() && getUserRole() != null;
    }

    // Invitations
    // - get (single doc): aviva user reads only their own, used at login
    // - list (query): admin only, used in UsersAdmin page
    match /invitations/{email} {
      allow get: if isAvivaDomain() && request.auth.token.email == email;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAvivaDomain();
      allow create: if isAvivaDomain() && request.auth.uid == userId;
      allow update: if isAdmin()
        || (isAvivaDomain()
            && request.auth.uid == userId
            && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Workspace settings
    match /workspace_settings/{docId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Templates
    match /templates/{templateId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Scheduled messages
    match /scheduled_messages/{messageId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Message history
    match /message_history/{historyId} {
      allow read: if isViewer();
      allow create: if isAvivaDomain();
      allow update, delete: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Campaign executions
    match /campaign_executions/{execId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isAdmin();
    }

    // HubSpot connections
    match /hubspot_connections/{connectionId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Rules
    match /rules/{ruleId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow update, delete: if isEditor()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Sales users
    match /sales_users/{userId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }
  }
}
